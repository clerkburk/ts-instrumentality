{
  "name": "ts-instrumentality",
  "type": "module",
  "version": "1.0.6",
  "main": "./dist/base.js",
  "types": "./dist/base.d.ts",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "exports": {
    ".": {
      "import": "./dist/base.js",
      "types": "./dist/base.d.ts"
    },
    "./road": {
      "import": "./dist/road.js",
      "types": "./dist/road.d.ts"
    },
    "./dom": {
      "import": "./dist/dom.js",
      "types": "./dist/dom.d.ts"
    },
    "./src/base": "./src/base.ts",
    "./src/road": "./src/road.ts",
    "./src/dom": "./src/dom.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
